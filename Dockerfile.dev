FROM python:3.11-slim

WORKDIR /app

# Runtime system deps only. We deliberately do NOT install a compiler or -dev
# headers:
#   - psycopg2-binary bundles libpq          → no libpq-dev
#   - matrix-nio is used without [e2e]/olm   → no libolm-dev
#   - all Python deps ship manylinux wheels  → no gcc at build time
# git is kept because the app shells out to it for promotion PRs and bundles.
RUN apt-get update && apt-get install -y --no-install-recommends \
    git ca-certificates && \
    rm -rf /var/lib/apt/lists/* && \
    git config --global --add safe.directory /app

# Python deps — copy only the dependency manifest first so this layer is
# invalidated only when dependencies change, not on every code change.
COPY pyproject.toml .
RUN mkdir -p app && touch app/__init__.py && \
    pip install --no-cache-dir -e ".[dev]"

# Source — copied last; changes here don't invalidate the layers above. At
# runtime docker-compose bind-mounts the project over /app, so this mainly keeps
# the image self-contained when run without the mount.
COPY . .

ENV FLASK_APP=wsgi.py
ENV FLASK_ENV=development

EXPOSE 5000

CMD ["flask", "run", "--host=0.0.0.0", "--debug"]
