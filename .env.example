SECRET_KEY=change-me-to-a-random-secret
DATABASE_URL=postgresql://autobot:autobot@postgres:5432/autobot
REDIS_URL=redis://redis:6379/0
FLASK_ENV=development
LOG_LEVEL=INFO

# OpenAI Codex OAuth
OPENAI_CLIENT_ID=
OPENAI_CLIENT_SECRET=
OPENAI_REDIRECT_URI=http://localhost:5000/api/oauth/openai/callback

# Token encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
TOKEN_ENCRYPTION_KEY=

# Agent defaults
OPENAI_MODEL=o4-mini
MAX_CONTEXT_TOKENS=128000
MAX_HISTORY_MESSAGES=50
# Hard cap on tool-call rounds per run. Individual agents can override this
# via the agents.max_tool_rounds column.
MAX_TOOL_ROUNDS=20

# Self-improvement rate limit: max patches (applied + pending_review) an
# agent may produce per rolling hour. Set to 0 to disable.
PATCHES_PER_HOUR_PER_AGENT=30

# Matrix integration (optional)
MATRIX_HOMESERVER=
MATRIX_USER_ID=
MATRIX_PASSWORD=
MATRIX_ALLOWED_ROOMS=
MATRIX_ALLOWED_USERS=
MATRIX_ALLOWED_DM_USERS=
MATRIX_GROUP_POLICY=mention

# Cost alert: show a warning on the Metrics dashboard when today's estimated
# cost (USD) reaches this threshold. Leave unset to disable.
# COST_ALERT_EUR_DAILY=1.00

# GitHub repo for promotion PRs. Override when working on a fork.
# Defaults to https://github.com/lliwi/autobot if not set.
# AUTOBOT_GITHUB_REPO=https://github.com/your-fork/autobot
# GH_TOKEN=ghp_...                 # token with `repo` scope (also used by incident autopilot)
# AUTOBOT_GITHUB_BASE_BRANCH=main  # base branch for auto-drafted PRs

# Incident autopilot: on ERROR/CRITICAL logs (or failed runs) a reviewer agent
# diagnoses the problem and drafts a GitHub Issue or PR; the draft waits for
# human approval in the Incidents dashboard before anything is opened on GitHub.
INCIDENT_AUTOPILOT_ENABLED=true
# Trigger threshold: "error" (ERROR+CRITICAL) or "critical" (CRITICAL only).
# WARNING is never auto-triggered.
INCIDENT_MIN_SEVERITY=error
# One incident per error signature per this many hours; repeats bump a counter.
INCIDENT_DEDUP_COOLDOWN_HOURS=12

# Scheduler
SCHEDULER_ENABLED=true
HEARTBEAT_INTERVAL_MINUTES=15
