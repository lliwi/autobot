SECRET_KEY=change-me-to-a-random-secret
DATABASE_URL=postgresql://autobot:autobot@postgres:5432/autobot
REDIS_URL=redis://redis:6379/0
FLASK_ENV=development
LOG_LEVEL=INFO

# OpenAI Codex OAuth
OPENAI_CLIENT_ID=
OPENAI_CLIENT_SECRET=
OPENAI_REDIRECT_URI=http://localhost:5000/api/oauth/openai/callback

# Token encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
TOKEN_ENCRYPTION_KEY=

# Agent defaults
OPENAI_MODEL=o4-mini
MAX_CONTEXT_TOKENS=128000
MAX_HISTORY_MESSAGES=50

# Matrix integration (optional)
MATRIX_HOMESERVER=
MATRIX_USER_ID=
MATRIX_PASSWORD=
MATRIX_ALLOWED_ROOMS=
MATRIX_ALLOWED_USERS=
MATRIX_GROUP_POLICY=mention

# Scheduler
SCHEDULER_ENABLED=true
HEARTBEAT_INTERVAL_MINUTES=15
